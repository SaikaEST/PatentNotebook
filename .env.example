# App
APP_NAME=patent-notebook
ENV=dev
API_PORT=8000
FRONTEND_PORT=3000

# Database
POSTGRES_DB=patent_notebook
POSTGRES_USER=patent
POSTGRES_PASSWORD=patent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://patent:patent@postgres:5432/patent_notebook

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=patent-notebook

# Security
JWT_SECRET=dev-secret
JWT_ALG=HS256
JWT_EXPIRES_MIN=120

# Feature flags
ENABLE_OIDC=false
ENABLE_SAML=false

# DMS fallback ingest
DMS_ROOT=/data/dms
DMS_RECURSIVE=false

# CNIPR ingest (optional)
CNIPR_BASE_URL=https://open.cnipr.com
CNIPR_CLIENT_ID=
CNIPR_CLIENT_SECRET=
CNIPR_USER_ACCOUNT=
CNIPR_USER_PASSWORD=
CNIPR_ACCESS_TOKEN=
CNIPR_OPENID=
CNIPR_TOKEN_EXPIRES_IN=3600
CNIPR_TIMEOUT_SEC=20
CNIPR_DBS=FMZL,FMSQ,SYXX,WGZL

# EPO OPS ingest (optional)
EPO_OPS_KEY=
EPO_OPS_SECRET=
EPO_OPS_TIMEOUT_SEC=30
EP_INGEST_OUT_DIR=/data
EP_REGISTER_ONLY=true
EP_REGISTER_BROWSER_FALLBACK=true
EP_REGISTER_BROWSER_HEADLESS=true
EP_REGISTER_BROWSER_USER_DATA_DIR=/data/.ep-browser

# OCR for scanned/image PDFs
ENABLE_PDF_OCR=true
PDF_OCR_MIN_CHARS=80
PDF_OCR_PAGE_MIN_CHARS=20
PDF_OCR_MAX_PAGES=40
PDF_OCR_SCALE=2.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
